+/* Sprint 02 additions */
+.sprint-banner {
+  display: flex;
+  grid-column: 1 / -1;
+  align-items: center;
+  justify-content: space-between;
+  gap: 18px;
+  padding: 20px 22px;
+  border: 1px solid #d6e5dc;
+  border-radius: 18px;
+  background:
+    linear-gradient(135deg, rgba(255,255,255,.96), rgba(232,242,236,.92)),
+    radial-gradient(circle at 20% 20%, rgba(84, 123, 104, .16), transparent 36%);
+  box-shadow: 0 16px 40px rgba(70, 88, 78, .10);
+}
+
+.sprint-banner h2 {
+  margin: 3px 0 6px;
+  font-size: clamp(1.35rem, 2vw, 2.2rem);
+}
+
+.sprint-banner span {
+  color: #64746c;
+}
+
+.sprint-banner > strong {
+  display: grid;
+  place-items: center;
+  width: 68px;
+  height: 68px;
+  border-radius: 20px;
+  color: #ffffff;
+  font-size: 1.75rem;
+  background: linear-gradient(135deg, #456d5b, #6e91aa);
+  box-shadow: 0 14px 32px rgba(69, 109, 91, .24);
+}
+
+.sprint-banner--security {
+  margin-bottom: 16px;
+}
+
+.security-workspace {
+  display: grid;
+  gap: 18px;
+}
+
+.security-summary-grid {
+  display: grid;
+  grid-template-columns: repeat(3, minmax(0, 1fr));
+  gap: 14px;
+}
+
+.security-summary-card {
+  display: grid;
+  gap: 7px;
+  padding: 18px;
+  border: 1px solid #dfe9e3;
+  border-radius: 16px;
+  background: #ffffff;
+  box-shadow: 0 12px 32px rgba(70, 88, 78, .08);
+}
+
+.security-summary-card svg {
+  color: #547b68;
+}
+
+.security-summary-card span,
+.security-summary-card small {
+  color: #68776f;
+}
+
+.security-summary-card strong {
+  font-size: 1.6rem;
+}
+
+.guardrail-panel {
+  padding: 18px;
+  border: 1px solid #dfe9e3;
+  border-radius: 16px;
+  background: #ffffff;
+  box-shadow: 0 12px 32px rgba(70, 88, 78, .08);
+}
+
+.guardrail-list {
+  display: grid;
+  gap: 10px;
+  margin-top: 12px;
+}
+
+.guardrail-list span {
+  padding: 11px 12px;
+  border-radius: 12px;
+  color: #33443b;
+  background: #f5f8f6;
+}
+
+.detail-field textarea {
+  min-height: 82px;
+  resize: vertical;
+  border: 1px solid #d8e2db;
+  border-radius: 10px;
+  padding: 10px 12px;
+  color: #1c2521;
+  background: #ffffff;
+}
+
+.detail-field--wide {
+  grid-column: 1 / -1;
+}
+
+.document-row small {
+  display: block;
+  color: #7a8b82;
+  font-size: .76rem;
+  margin-top: 3px;
+}
+
+@media (max-width: 980px) {
+  .security-summary-grid {
+    grid-template-columns: 1fr;
+  }
+
+  .sprint-banner {
+    align-items: flex-start;
+    flex-direction: column;
+  }
+}
